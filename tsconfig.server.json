{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist/server",
    "declaration": false,
    "sourceMap": true
  },
  "include": ["server/**/*.ts", "src/lib/netscape.ts"],
  "exclude": ["node_modules"]
}

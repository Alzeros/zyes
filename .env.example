# ZYES Environment Configuration
# Copy to .env and fill in values

# Server port (default: 3847)
ZYES_PORT=3847

# Server host (default: 0.0.0.0)
ZYES_HOST=0.0.0.0

# Admin password (used on first run to generate hash)
ZYES_PASSWORD=changeme

# Data directory override (for Docker volumes)
# ZYES_DATA_DIR=./server/data

{
  "name": "zyes",
  "version": "0.0.2",
  "description": "A lightweight, cross-device bookmark navigation and aggregated search portal",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:client:worker": "VITE_API_TARGET=http://127.0.0.1:8787 vite",
    "dev:server": "tsx watch server/index.ts",
    "dev:worker:client": "concurrently -k \"npm run dev:worker\" \"npm run dev:client:worker\"",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "init": "tsx scripts/init.ts",
    "dev:worker": "wrangler dev --config wrangler.dev.toml",
    "deploy": "wrangler deploy --keep-vars",
    "import-d1": "tsx scripts/import-to-d1.ts",
    "cf-typecheck": "tsc -p tsconfig.worker.json --noEmit"
  },
  "license": "MIT",
  "cloudflare": {
    "bindings": {
      "ZYES_PASSWORD": {
        "type": "plain-text",
        "description": "你登录 zyes 用的密码。自己定一个，部署后用这个密码登录。"
      },
      "JWT_SECRET": {
        "type": "plain-text",
        "description": "签发登录 token 的密钥。务必改成随机串，不要用占位值！生成: openssl rand -hex 32"
      }
    }
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "^9.3.0",
    "@iconify/svelte": "^5.2.2",
    "bcryptjs": "^3.0.3",
    "fastify": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.1.16",
    "write-file-atomic": "^8.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260712.1",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.1",
    "@types/write-file-atomic": "^4.0.3",
    "concurrently": "^10.0.3",
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "pino-pretty": "^13.1.3",
    "svelte": "^5.56.4",
    "svelte-dnd-action": "^0.9.70",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "wrangler": "^4.110.0"
  }
}
